6px;background-color:#e5e7eb;text-align:center;font-size:11px;}QProgressBar::chunk{background-color:#6366f1;border-radius:6px;}QCheckBox{font-size:13px;color:#374151;spacing:8px;}QCheckBox::indicator{width:18px;height:18px;border-radius:4px;border:1px solid #d1d5db;background:#f9fafb;}QCheckBox::indicator:checked{background:#6366f1;border-color:#6366f1;}QScrollBar:vertical{background:#f5f5fa;width:6px;border-radius:3px;}QScrollBar::handle:vertical{background:#d1d5db;border-radius:3px;min-height:20px;}</string>
